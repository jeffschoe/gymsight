{
  "compilerOptions": {
    //"baseUrl": ".", deprecated
    "target": "esnext",
    "module": "nodenext",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["./src/**/*.ts", "src/server/routes"],
  "exclude": ["node_modules"]
}